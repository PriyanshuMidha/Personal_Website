PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://localhost:3000
MONGO_URI=
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Login API test — replace with the same ADMIN_EMAIL / ADMIN_PASSWORD you use for `npm run seed:admin`.
# Using literals like YOUR_ADMIN_EMAIL in JSON will fail validation (400): they are not valid emails.
# Password must match exactly what was hashed when the admin was seeded (same as ADMIN_PASSWORD in .env).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
